{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arches Graphs Registry Schema",
  "description": "JSON Schema for graphs.json registry file used by Alizarin",
  "type": "object",
  "required": [
    "models"
  ],
  "properties": {
    "models": {
      "type": "object",
      "patternProperties": {
        "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$": {
          "$ref": "#/definitions/modelReference"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    }
  },
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "multilingualString": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "modelReference": {
      "type": "object",
      "required": [
        "id",
        "name",
        "slug"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/uuid"
        },
        "name": {
          "$ref": "#/definitions/multilingualString"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
          "minLength": 2
        },
        "subtitle": {
          "$ref": "#/definitions/multilingualString"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-f]{6}$"
        },
        "iconclass": {
          "type": "string",
          "pattern": "^fa fa-[a-z-]+$"
        }
      }
    }
  }
}