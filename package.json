{
  "name": "alizarin",
  "version": "0.2.1-alpha.21",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "files": [
    "dist",
    "pkg"
  ],
  "main": "./dist/alizarin.umd.cjs",
  "module": "./dist/alizarin.js",
  "browser": {
    "fs": false,
    "path": false,
    "url": false,
    "crypto": false,
    "stream": false,
    "util": false,
    "events": false,
    "buffer": false,
    "os": false
  },
  "exports": {
    ".": {
      "import": "./dist/alizarin.js",
      "require": "./dist/alizarin.umd.cjs"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    }
  },
  "scripts": {
    "build:wasm": "wasm-pack build crates/alizarin-wasm --target web --out-dir ../../pkg --out-name alizarin --release",
    "build:wasm:dev": "wasm-pack build crates/alizarin-wasm --target web --out-dir ../../pkg --out-name alizarin --dev",
    "build:js": "NODE_OPTIONS='--experimental-wasm-modules' vite build",
    "build": "npm run build:wasm && npm run build:js",
    "prebuild": "npm run build:wasm",
    "prepublishOnly": "npm run build",
    "test": "NODE_OPTIONS='--experimental-wasm-modules' vitest --run",
    "test:watch": "NODE_OPTIONS='--experimental-wasm-modules' vitest",
    "test:ui": "NODE_OPTIONS='--experimental-wasm-modules' vitest --ui",
    "lint": "eslint js --ext .ts",
    "dev": "NODE_OPTIONS='--experimental-wasm-modules' vite serve .",
    "validate": "NODE_OPTIONS='--experimental-wasm-modules' node validate-graphs.mjs",
    "version:sync": "./scripts/sync-version.sh",
    "version:set": "./scripts/sync-version.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@fetch-mock/vitest": "^0.2.13",
    "@types/node": "^22.14.0",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "puppeteer": "^24.24.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^5.4.18",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^2.1.5",
    "vitest-fetch-mock": "^0.4.2",
    "wasm-pack": "^0.13.1"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "geojson": "^0.5.0",
    "uuid": "^11.1.0"
  }
}
